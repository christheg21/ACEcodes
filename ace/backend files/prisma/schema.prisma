// Prisma schema for ACE card games platform
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  usernameLower String  @unique @map("username_lower")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Overall stats (denormalised for fast reads)
  gamesPlayed  Int      @default(0) @map("games_played")
  wins         Int      @default(0)
  losses       Int      @default(0)
  elo          Int      @default(1200)

  // Relations
  gameStats    GameStat[]
  matchHistory MatchPlayer[]

  @@index([elo(sort: Desc)])   // overall leaderboard
  @@map("users")
}

// ── Per-game stats ─────────────────────────────────────
model GameStat {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  game        String   // 'durak' | 'shithead' | 'gofish'
  gamesPlayed Int      @default(0) @map("games_played")
  wins        Int      @default(0)
  losses      Int      @default(0)
  elo         Int      @default(1200)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, game])
  @@index([elo(sort: Desc)])   // leaderboard ORDER BY elo DESC
  @@map("game_stats")
}

// ── Match records ──────────────────────────────────────
model Match {
  id          String        @id @default(uuid())
  game        String        // 'durak' | 'shithead' | 'gofish'
  mode        String        // 'casual' | 'ranked'
  roomId      String?       @map("room_id")
  roomName    String?       @map("room_name")
  startedAt   DateTime      @default(now()) @map("started_at")
  finishedAt  DateTime?     @map("finished_at")
  durationSec Int?          @map("duration_sec")
  rounds      Int           @default(0)

  players     MatchPlayer[]

  @@index([finishedAt(sort: Desc)])  // ORDER BY finished_at DESC
  @@map("matches")
}

// ── Per-player match result ────────────────────────────
model MatchPlayer {
  id          String   @id @default(uuid())
  matchId     String   @map("match_id")
  userId      String   @map("user_id")
  place       Int      // finishing position (1 = first out / winner)
  eloChange   Int      @default(0) @map("elo_change")
  eloBefore   Int      @map("elo_before")
  eloAfter    Int      @map("elo_after")

  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])    // getMatchHistory queries by userId
  @@map("match_players")
}
